# Dependencies
/node_modules
/.dalt/node_modules
/vendor

# Environment variables
.env

# IDE files
/.idea
/.vscode

# OS files
.DS_Store
Thumbs.db

# Build outputs (keep .gitkeep files)
/public/css/*
!/public/css/.gitkeep
/public/js/*
!/public/js/.gitkeep
/public/build/*
!/public/build/.gitkeep

# Logs
/storage/logs/*
!/storage/logs/.gitkeep
*.log

# Temporary files
*.tmp
*.temp

# Challenge runtime state (from php artisan challenge:start)
.dalt/active_challenge.txt
.dalt/progress.json
.dalt/baseline/

# Database files
/database/*.sqlite
/database/*.db
!/database/.gitkeep
!/database/migrations/

/docs/CODE_REVIEW_WALKTHROUGH.md
/docs/NEW_CODE_REVIEW.md
