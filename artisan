#!/usr/bin/env php
<?php

$arguments = $argv;

function load_env_and_boot(): array {
    if (!defined('BASE_PATH')) {
        define('BASE_PATH', __DIR__ . '/');
    }
    if (!function_exists('base_path')) {
        function base_path(string $path = ''): string {
            return BASE_PATH . $path;
        }
    }
    require base_path('vendor/autoload.php');
    // Load env if present, otherwise continue silently
    $dotenv = Dotenv\Dotenv::createImmutable(base_path(''));
    if (method_exists($dotenv, 'safeLoad')) {
        $dotenv->safeLoad();
    } else {
        try { $dotenv->load(); } catch (\Throwable $e) { /* ignore missing .env */ }
    }
    $dbConfig = require base_path('config/database.php');
    return $dbConfig;
}

if (count($arguments) < 2 || $arguments[1] === 'help' || $arguments[1] === '--help' || $arguments[1] === '-h') {
    echo "\n";
    echo "╔══════════════════════════════════════════════════════════════╗\n";
    echo "║                    DALT.PHP Artisan CLI                      ║\n";
    echo "╚══════════════════════════════════════════════════════════════╝\n";
    echo "\n";
    echo "Usage: php artisan <command> [options]\n";
    echo "\n";
    echo "Available Commands:\n";
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n";
    echo "\n";
    
    echo "  dalt:test [challenge]   Run the test suite globally or for a specific challenge\n";
    echo "                          Example: php artisan dalt:test broken-auth\n";
    echo "\nDevelopment:\n";
    echo "  serve [host] [port]     Start PHP development server\n";
    echo "                          Example: php artisan serve\n";
    echo "                          Example: php artisan serve 0.0.0.0 8080\n";
    echo "\n";
    echo "  dev                     Start both PHP and Vite dev servers\n";
    echo "                          (Runs in background, use Ctrl+C to stop)\n";
    echo "\n";
    echo "Database:\n";
    echo "  migrate                 Run pending database migrations\n";
    echo "                          Executes .sql files from database/migrations/\n";
    echo "\n";
    echo "  migrate:fresh           Drop database and run all migrations\n";
    echo "                          WARNING: Deletes all data! (SQLite only)\n";
    echo "\n";
    echo "  make:migration <name>   Create a new SQL migration file\n";
    echo "                          Example: php artisan make:migration create_posts_table\n";
    echo "\n";
    echo "Testing:\n";
    echo "  test                    Run Pest test suite\n";
    echo "                          Executes all tests in tests/ directory\n";
    echo "\n";
    echo "  verify <challenge>      Verify a challenge solution\n";
    echo "                          Example: php artisan verify broken-routing\n";
    echo "                          Available: broken-routing, broken-middleware,\n";
    echo "                                     broken-auth, broken-database, broken-session\n";
    echo "\n";
    echo "Examples:\n";
    echo "  example:install auth    Install authentication example\n";
    echo "                          Copies controllers, views, and routes\n";
    echo "\n";
    echo "Help:\n";
    echo "  help                    Show this help message\n";
    echo "\n";
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n";
    echo "\n";
    echo "For more information, visit: https://github.com/Ibnu-Afdel/DALT.PHP\n";
    echo "\n";
    exit(0);
}

// Bootstrap core for all commands so helpers like base_path() exist
$dbConfigBoot = load_env_and_boot();

$command = $arguments[1];

switch ($command) {
    case 'serve':
        $host = $arguments[2] ?? '127.0.0.1';
        $port = (int) ($arguments[3] ?? 8000);
        $maxTries = 50;
        $chosenPort = $port;
        $isFree = function(string $h, int $p): bool {
            $conn = @fsockopen($h, $p, $errno, $errstr, 0.2);
            if (is_resource($conn)) { fclose($conn); return false; }
            return true;
        };
        while ($maxTries-- > 0 && !$isFree($host, $chosenPort)) {
            $chosenPort++;
        }
        if ($chosenPort !== $port) {
            echo "Port {$port} in use. Using {$chosenPort} instead.\n";
        }
        echo "Starting development server: http://{$host}:{$chosenPort}\n";
        // Use router script for static files + front-controller routing
        passthru("php -S {$host}:{$chosenPort} -t public public/router.php");
        break;

    
    case 'dalt:test':
        $dirs = array_filter(glob(base_path('course/challenges/*')), 'is_dir');
        $challenges = array_map('basename', $dirs);
        
        $target = $arguments[2] ?? null;
        if ($target && in_array($target, $challenges)) {
            $challenges = [$target];
        } else if ($target) {
            echo "Challenge '$target' not found.\n";
            exit(1);
        }

        echo "\n=================================================\n";
        echo "             DALT.PHP TEST RUNNER                \n";
        echo "=================================================\n\n";

        require_once base_path('framework/Core/ChallengeVerifier.php');

        $totalTests = 0;
        $totalPassed = 0;

        foreach ($challenges as $ch) {
            echo "\033[1;36mChallenge: $ch\033[0m\n";
            $verifier = new \Core\ChallengeVerifier("course/challenges/$ch");
            $result = $verifier->verify();
            
            $tests = $result['results'] ?? [];
            $chPassed = $result['passed'] ?? 0;
            $chTotal = $result['total'] ?? 0;
            
            $totalTests += $chTotal;
            $totalPassed += $chPassed;

            foreach ($tests as $name => $test) {
                if ($test['passed']) {
                    echo "  \033[32m✔ {$test['name']}\033[0m\n";
                } else {
                    echo "  \033[31m✘ {$test['name']}\033[0m - {$test['message']}\n";
                }
            }
            if ($chTotal === 0) {
                 echo "  \033[33mNo tests configured or found.\033[0m\n\n";
            } else if ($chPassed === $chTotal) {
                 echo "  \033[1;32mStatus: PASSED ($chPassed/$chTotal)\033[0m\n\n";
            } else {
                 echo "  \033[1;31mStatus: FAILED ($chPassed/$chTotal)\033[0m\n\n";
            }
        }
        
        echo "=================================================\n";
        echo " Total Progress: $totalPassed / $totalTests tests passed.\n";
        echo "=================================================\n\n";
        break;

    case 'migrate':
        $dbConfig = $dbConfigBoot;
        $database = new Core\Database($dbConfig['database']);
        $migration = new Core\Migration($database);
        $migration->runMigrations();
        echo "Migration process completed.\n";
        break;

    case 'migrate:fresh':
        $dbConfig = $dbConfigBoot;
        echo "Running migrate:fresh...\n";
        if (($dbConfig['database']['driver'] ?? 'sqlite') === 'sqlite') {
            $dbPath = $dbConfig['database']['database'];
            if (file_exists($dbPath)) {
                unlink($dbPath);
                echo "Dropped existing database file.\n";
            }
        } else {
            echo "Warning: migrate:fresh for non-SQLite databases not implemented yet.\n";
        }
        $database = new Core\Database($dbConfig['database']);
        $migration = new Core\Migration($database);
        $migration->runMigrations();
        echo "Fresh migration completed.\n";
        break;

    case 'make:migration':
        if (!isset($arguments[2])) {
            echo "Usage: php artisan make:migration <name>\n";
            echo "Example: php artisan make:migration create_posts_table\n";
            exit(1);
        }
        
        $name = $arguments[2];
        // Clean the name: remove 'create_' prefix and '_table' suffix if present
        $cleanName = preg_replace('/^create_/', '', $name);
        $cleanName = preg_replace('/_table$/', '', $cleanName);
        
        // Generate filename with timestamp
        $timestamp = date('YmdHis');
        $filename = "{$timestamp}_{$name}.sql";
        $filepath = base_path("database/migrations/{$filename}");
        
        if (!is_dir(base_path('database/migrations'))) {
            mkdir(base_path('database/migrations'), 0755, true);
        }
        
        // Generate SQL template
        $currentDate = date('Y-m-d H:i:s');
        $template = <<<SQL
-- Migration: {$name}
-- Created: {$currentDate}

CREATE TABLE IF NOT EXISTS {$cleanName} (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name VARCHAR(255) NOT NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- Add indexes here
-- CREATE INDEX IF NOT EXISTS idx_{$cleanName}_name ON {$cleanName}(name);

-- Notes:
-- SQLite: INTEGER PRIMARY KEY AUTOINCREMENT
-- MySQL:  INT AUTO_INCREMENT PRIMARY KEY
-- PostgreSQL: SERIAL PRIMARY KEY
SQL;
        
        file_put_contents($filepath, $template);
        echo "Migration created: database/migrations/{$filename}\n";
        echo "\n";
        echo "Next steps:\n";
        echo "1. Edit the migration file to define your table structure\n";
        echo "2. Run: php artisan migrate\n";
        break;

    case 'example:install':
        $which = $arguments[2] ?? '';
        if ($which !== 'auth') {
            echo "Usage: php artisan example:install auth\n";
            exit(1);
        }
        $source = base_path('.dalt/stubs/auth');
        if (!is_dir($source)) {
            echo "Examples not found.\n";
            exit(1);
        }
        // Copy controllers
        @mkdir(base_path('Http/controllers/session'), 0755, true);
        @mkdir(base_path('Http/controllers/registration'), 0755, true);
        foreach (['session/create.php','session/store.php','session/destroy.php','registration/create.php','registration/store.php'] as $file) {
            copy($source . '/Http/controllers/' . $file, base_path('Http/controllers/' . $file));
        }
        // Copy views
        @mkdir(base_path('resources/views/auth'), 0755, true);
        foreach (['auth/login.view.php','auth/register.view.php'] as $file) {
            copy($source . '/resources/views/' . $file, base_path('resources/views/' . $file));
        }
        // Append routes
        $routesPath = base_path('routes/routes.php');
        $routeBlock = "\n// Auth example routes\n"
            . "\$router->get('/register', 'registration/create.php')->only('guest');\n"
            . "\$router->post('/register', 'registration/store.php')->only(['guest','csrf']);\n"
            . "\$router->get('/login', 'session/create.php')->only('guest');\n"
            . "\$router->post('/session', 'session/store.php')->only(['guest','csrf']);\n"
            . "\$router->delete('/session', 'session/destroy.php')->only(['auth','csrf']);\n";
        file_put_contents($routesPath, $routeBlock, FILE_APPEND);
        // Create marker so UI can show CTAs
        @mkdir(base_path('storage'), 0755, true);
        file_put_contents(base_path('storage/auth_example_installed'), date('c'));
        echo "Auth example installed and routes appended to routes/routes.php.\n";
        echo "Visit /register or /login (or see buttons on the welcome page).\n";
        break;

    case 'verify':
        $challengeName = $arguments[2] ?? '';
        if (empty($challengeName)) {
            echo "Usage: php artisan verify <challenge-name>\n";
            echo "Example: php artisan verify broken-routing\n";
            echo "\nAvailable challenges:\n";
            echo "  - broken-routing\n";
            echo "  - broken-middleware\n";
            echo "  - broken-auth\n";
            echo "  - broken-database\n";
            echo "  - broken-session\n";
            exit(1);
        }

        $challengePath = "course/challenges/{$challengeName}";
        
        if (!is_dir(base_path($challengePath))) {
            echo "Error: Challenge '{$challengeName}' not found.\n";
            echo "Make sure the challenge exists in course/challenges/ directory.\n";
            exit(1);
        }

        echo "\n";
        echo "╔══════════════════════════════════════════════════════════════╗\n";
        echo "║           DALT Challenge Verification System                ║\n";
        echo "╚══════════════════════════════════════════════════════════════╝\n";
        echo "\n";
        echo "Verifying: {$challengeName}\n";
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n";

        $verifier = new Core\ChallengeVerifier($challengePath);
        $result = $verifier->verify();

        // Display results
        foreach ($result['results'] as $test) {
            $icon = $test['passed'] ? '✓' : '✗';
            $color = $test['passed'] ? "\033[32m" : "\033[31m";
            $reset = "\033[0m";
            
            echo "{$color}{$icon}{$reset} {$test['message']}\n";
            
            if (!$test['passed'] && !empty($test['hint'])) {
                echo "  💡 Hint: {$test['hint']}\n";
            }
        }

        echo "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n";
        echo "Results: {$result['passed']}/{$result['total']} tests passed\n";
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n";

        if ($result['status'] === 'pass') {
            echo "🎉 {$result['message']}\n\n";
            echo "Great job! You've successfully fixed this challenge.\n";
            echo "Check storage/logs/challenges.log for your progress.\n";
        } else {
            echo "❌ {$result['message']}\n\n";
            if (!empty($result['hint'])) {
                echo "💡 Next step: {$result['hint']}\n\n";
            }
            echo "Keep debugging! Check the challenge README for more hints.\n";
        }

        echo "\n";

        // Log result
        Core\ChallengeVerifier::logResult($challengeName, $result);
        
        exit($result['status'] === 'pass' ? 0 : 1);

    case 'dev':
        echo "Starting DALT.PHP development environment...\n";
        echo "\n";
        echo "This will start:\n";
        echo "  1. PHP development server (port 8000)\n";
        echo "  2. Vite dev server (port 5173)\n";
        echo "\n";
        echo "Press Ctrl+C to stop both servers.\n";
        echo "\n";
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n";
        
        // Check if npm is available
        exec('which npm', $output, $npmCheck);
        if ($npmCheck !== 0) {
            echo "⚠️  Warning: npm not found. Vite server will not start.\n";
            echo "   Install Node.js to enable the frontend: https://nodejs.org/\n";
            echo "\n";
            echo "Starting PHP server only...\n";
            passthru("php artisan serve");
            exit(0);
        }
        
        // Start both servers using concurrently if available, otherwise use background processes
        if (file_exists(base_path('.dalt/node_modules/.bin/concurrently'))) {
            passthru('cd ' . base_path('.dalt') . ' && npm run dev & php artisan serve');
        } else {
            echo "Starting servers...\n";
            echo "  → PHP server: http://localhost:8000\n";
            echo "  → Vite server: http://localhost:5173\n";
            echo "\n";
            
            // Start Vite in background
            $viteCmd = 'cd ' . base_path('.dalt') . ' && npm run dev > /dev/null 2>&1 &';
            exec($viteCmd);
            
            sleep(2); // Give Vite time to start
            
            // Start PHP server in foreground
            passthru("php artisan serve");
        }
        break;

    case 'test':
        echo "Running Pest test suite...\n";
        echo "\n";
        
        if (!file_exists(base_path('vendor/bin/pest'))) {
            echo "⚠️  Pest is not installed.\n";
            echo "\n";
            echo "Install Pest by running:\n";
            echo "  composer require pestphp/pest --dev\n";
            echo "\n";
            exit(1);
        }
        
        passthru('vendor/bin/pest');
        break;

    case 'help':
    case '--help':
    case '-h':
        // Help is handled at the top, but include here for completeness
        passthru("php artisan");
        break;

    default:
        echo "Unknown command: $command\n";
        echo "Run 'php artisan help' to see available commands.\n";
        exit(1);
}
